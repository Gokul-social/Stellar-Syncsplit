# Soroban Contract Configuration
VITE_CONTRACT_ID=your_deployed_contract_id_here
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
VITE_HORIZON_URL=https://horizon-testnet.stellar.org
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Fee Sponsorship — Gasless Transactions (Advanced Feature)
# Set VITE_SPONSOR_SECRET to a funded Stellar keypair SECRET key.
# This account will pay transaction fees on behalf of users (fee bump).
# WARNING: In production, this key must live in a backend service, NOT in the frontend.
# For testnet demos, embedding in .env.local is acceptable.
VITE_SPONSOR_SECRET=your_sponsor_secret_key_here
VITE_SPONSOR_PUBLIC=your_sponsor_public_key_here
